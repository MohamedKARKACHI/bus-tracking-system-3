{
  "name": "bus-tracking-system",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && ./gradlew bootRun",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd backend && ./gradlew build",
    "install:all": "cd frontend && npm install",
    "test:backend": "cd backend && ./gradlew test"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "description": "A comprehensive bus tracking and management system built with Next.js, featuring real-time GPS tracking, ticket booking, and fleet management.",
  "main": "index.js",
  "keywords": [],
  "author": "",
  "license": "ISC"
}
